import ccxt
import pandas as pd
import time
import sys
import numpy as np # Import numpy untuk pengecekan NaN

# Import konfigurasi kunci dari file config.py
try:
    from config import API_KEY, SECRET_KEY, EXCHANGE_NAME, SYMBOL, PERCENTAGE_PER_TRADE
except ImportError:
    print("Kesalahan: File config.py tidak ditemukan atau kunci API tidak lengkap.")
    sys.exit()

# --- Konfigurasi Indikator ---
RSI_PERIOD = 14
OVERSOLD_LEVEL = 30
OVERBOUGHT_LEVEL = 70
INTERVAL = '15m' # Interval data (Contoh: 15 menit)
POSITION = 0 # 0: Flat, 1: Long (Sedang memegang aset)

# Ambil base currency (misalnya USDT dari BTC/USDT)
BASE_CURRENCY = SYMBOL.split('/')[1] 
# Ambil quote currency (misalnya BTC dari BTC/USDT)
QUOTE_CURRENCY = SYMBOL.split('/')[0]

# --- Inisialisasi Exchange dan Koneksi API ---
try:
    # Menginisialisasi koneksi CCXT dengan kunci API
    exchange_class = getattr(ccxt, EXCHANGE_NAME.lower())
    exchange = exchange_class({
        'apiKey': API_KEY,
        'secret': SECRET_KEY,
        'enableRateLimit': True, # Untuk menghindari melebihi batas request API
    })
    print(f"Koneksi berhasil ke Exchange: {exchange.name}")
except AttributeError:
    print(f"Kesalahan: Exchange '{EXCHANGE_NAME}' tidak didukung oleh CCXT.")
    sys.exit()
except Exception as e:
    print(f"Kesalahan Koneksi API: {e}")
    sys.exit()

# --- FUNGSI BARU: MENGAMBIL SALDO DARI EXCHANGE ---
def get_balance(currency):
    """Mengambil saldo (available) dari mata uang tertentu."""
    try:
        # ccxt.fetch_balance() mengembalikan semua saldo akun
        balance = exchange.fetch_balance()
        # Mengambil saldo yang tersedia untuk trading
        available_balance = balance['free'].get(currency, 0.0) 
        return available_balance
    except Exception as e:
        print(f"Gagal mengambil saldo {currency} dari exchange: {e}")
        return 0.0

# --- Fungsi Perhitungan RSI (Tidak Berubah) ---
def calculate_rsi(df, period=14):
    if len(df) < period:
        return None
        
    delta = df['Close'].diff()
    gain = delta.where(delta > 0, 0)
    loss = -delta.where(delta < 0, 0)
    
    avg_gain = gain.ewm(com=period - 1, min_periods=period).mean()
    avg_loss = loss.ewm(com=period - 1, min_periods=period).mean()
    
    rs = avg_gain / avg_loss
    rsi = 100 - (100 / (1 + rs))
    
    return rsi.iloc[-1]

# --- Fungsi Trading (Sedikit Modifikasi) ---
def execute_trade(side, amount_base, amount_quote, symbol):
    """
    Menempatkan order pasar (Market Order) di exchange.
    Untuk beli: amount_base adalah dana yang dibelanjakan (misal: USDT).
    Untuk jual: amount_quote adalah aset yang dimiliki (misal: BTC).
    """
    global POSITION
    
    print(f"\n--- MENEMPATKAN ORDER: {side.upper()} {amount_quote:.8f} {QUOTE_CURRENCY} ---")
    
    try:
        if side == 'buy':
            # Untuk BELI, kita menggunakan dana (BASE_CURRENCY) untuk menentukan kuantitas
            # Order amount dalam CCXT biasanya adalah QTY aset yang akan dibeli (QUOTE_CURRENCY)
            # Karena exchange biasanya butuh qty (contoh: 0.001 BTC), bukan modal (contoh: 10 USDT), 
            # kita harus membiarkan CCXT menghitungnya dengan parameter 'cost'.
            order = exchange.create_market_buy_order(symbol, amount_quote) 
            POSITION = 1
            print(f"Order BELI berhasil! ID: {order['id']}, Dibeli: {order['amount']:.8f} {QUOTE_CURRENCY}")
        
        elif side == 'sell':
            # Untuk JUAL, amount adalah QTY aset yang akan dijual (QUOTE_CURRENCY)
            order = exchange.create_market_sell_order(symbol, amount_quote)
            POSITION = 0
            print(f"Order JUAL berhasil! ID: {order['id']}, Dijual: {order['amount']:.8f} {QUOTE_CURRENCY}")
        
        return order
    except Exception as e:
        print(f"Gagal menempatkan order {side}: {e}")
        return None

# --- Fungsi Utama Bot ---
def run_bot():
    global POSITION
    
    print(f"Memulai Bot RSI Live untuk {SYMBOL} di {exchange.name}...")
    print(f"Risiko per Trade: {PERCENTAGE_PER_TRADE * 100:.2f}% dari saldo {BASE_CURRENCY}")
    print("---------------------------------------------------------")
    
    while True:
        try:
            # 1. Ambil Data Harga (OHLCV)
            ohlcv = exchange.fetch_ohlcv(symbol=SYMBOL, timeframe=INTERVAL, limit=RSI_PERIOD + 10)
            df = pd.DataFrame(ohlcv, columns=['timestamp', 'Open', 'High', 'Low', 'Close', 'Volume'])
            df['timestamp'] = pd.to_datetime(df['timestamp'], unit='ms')
            
            # 2. Hitung RSI dan Harga
            current_rsi = calculate_rsi(df, RSI_PERIOD)
            last_close_price = df['Close'].iloc[-1]
            
            # 3. Ambil Saldo Live
            base_balance = get_balance(BASE_CURRENCY) # Saldo dana (misal: USDT)
            quote_balance = get_balance(QUOTE_CURRENCY) # Saldo aset (misal: BTC)

            # 4. Tampilkan Status
            print(f"[{pd.Timestamp.now().strftime('%Y-%m-%d %H:%M:%S')}] Harga: {last_close_price:,.2f} | RSI: {current_rsi:5.2f} | Saldo {BASE_CURRENCY}: {base_balance:,.2f} | Posisi: {'LONG' if POSITION == 1 else 'FLAT'}")

            if np.isnan(current_rsi):
                print("Menunggu data RSI...")
                time.sleep(15)
                continue

            # 5. Logic Trading
            
            # Aturan BELI (Oversold)
            if current_rsi <= OVERSOLD_LEVEL and POSITION == 0:
                
                # Hitung jumlah dana yang akan digunakan berdasarkan persentase
                amount_to_spend = base_balance * PERCENTAGE_PER_TRADE
                
                # Hitung kuantitas aset yang dapat dibeli (qty BTC = $ / harga)
                # Catatan: Kita harus memastikan kuantitas ini sesuai dengan minimum order exchange.
                amount_to_buy_quote = amount_to_spend / last_close_price
                
                if amount_to_spend > 0 and amount_to_buy_quote > 0.0001: # Asumsi min order qty 0.0001
                    print(f"*** SIGNAL BELI DITEMUKAN! RSI ({current_rsi:.2f}) <= {OVERSOLD_LEVEL} ***")
                    print(f"Menggunakan {amount_to_spend:,.2f} {BASE_CURRENCY} ({PERCENTAGE_PER_TRADE * 100:.2f}%) untuk beli.")
                    
                    # NOTE: Untuk CCXT, saat BUY market order, parameter 'amount' adalah kuantitas aset yang dibeli (QUOTE)
                    # Kita menggunakan amount_to_buy_quote sebagai estimasi kuantitas.
                    execute_trade('buy', amount_to_spend, amount_to_buy_quote, SYMBOL)
                else:
                    print(f"Saldo {BASE_CURRENCY} tidak cukup atau terlalu kecil untuk dibeli.")

            # Aturan JUAL (Overbought)
            elif current_rsi >= OVERBOUGHT_LEVEL and POSITION == 1:
                
                # Jual semua aset yang kita miliki
                amount_to_sell = quote_balance
                
                if amount_to_sell > 0.0001: # Asumsi min order qty 0.0001
                    print(f"*** SIGNAL JUAL DITEMUKAN! RSI ({current_rsi:.2f}) >= {OVERBOUGHT_LEVEL} ***")
                    print(f"Menjual semua {QUOTE_CURRENCY} ({amount_to_sell:.8f} unit).")
                    
                    # NOTE: Untuk CCXT, saat SELL market order, parameter 'amount' adalah kuantitas aset yang dijual (QUOTE)
                    execute_trade('sell', None, amount_to_sell, SYMBOL) 
                else:
                    # Posisi mungkin sudah terjual (sudah flat) atau saldo quote_balance sangat kecil
                    print(f"Saldo {QUOTE_CURRENCY} terlalu kecil untuk dijual atau posisi sudah flat.")
                    POSITION = 0
                
            else:
                pass # HOLD

            # Jeda agar tidak terlalu banyak request ke API (misal: setiap 15 detik)
            time.sleep(15) 

        except Exception as e:
            print(f"Terjadi kesalahan saat menjalankan loop bot: {e}")
            # Jeda lebih lama jika ada error
            time.sleep(60) 

# --- Jalankan Bot ---
if __name__ == "__main__":
    run_bot()
